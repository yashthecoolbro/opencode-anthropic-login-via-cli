{
  "name": "opencode-anthropic-login-via-cli",
  "version": "1.3.3",
  "description": "OpenCode plugin that syncs your Claude CLI OAuth token to use Anthropic models with your Claude Pro/Max subscription.",
  "keywords": [
    "anthropic",
    "claude",
    "oauth",
    "opencode",
    "plugin",
    "token-sync"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cemalturkcan/opencode-anthropic-login-via-cli.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.7.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "refactor",
              "release": "patch"
            },
            {
              "type": "perf",
              "release": "patch"
            },
            {
              "type": "chore",
              "scope": "deps",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
