{
  "name": "opencode-anthropic-login-via-cli",
  "version": "1.3.1",
  "description": "OpenCode plugin that syncs your Claude CLI OAuth token to use Anthropic models with your Claude Pro/Max subscription.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "anthropic",
    "claude",
    "oauth",
    "token-sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cemalturkcan/opencode-anthropic-login-via-cli.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "typescript": "^5.7.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
